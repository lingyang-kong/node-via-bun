#!/bin/sh
set -eu

dpkg-buildpackage -us -uc -b

install -d dist public/pool/main/n/nodejs
mv ../nodejs_*_all.deb dist/
cp dist/*.deb public/pool/main/n/nodejs/

cd public

install -d dists/stable/main/binary-amd64
apt-ftparchive packages pool >dists/stable/main/binary-amd64/Packages
gzip -9c dists/stable/main/binary-amd64/Packages >dists/stable/main/binary-amd64/Packages.gz

apt-ftparchive \
	-o APT::FTPArchive::Release::Origin='node-via-bun' \
	-o APT::FTPArchive::Release::Label='node-via-bun' \
	-o APT::FTPArchive::Release::Suite='stable' \
	-o APT::FTPArchive::Release::Codename='stable' \
	-o APT::FTPArchive::Release::Architectures='amd64' \
	-o APT::FTPArchive::Release::Components='main' \
	release dists/stable >dists/stable/Release

printf '%s' "${APT_GPG_PRIVATE_KEY}" | gpg --batch --import
key_id="$(gpg --batch --list-secret-keys --with-colons | awk -F: '/^sec:/ { print $5; exit }')"
gpg --batch --yes --armor --export "${key_id}" >key.gpg
gpg --batch --yes --clearsign -u "${key_id}" \
	-o dists/stable/InRelease dists/stable/Release
